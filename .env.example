# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/squid_games

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Telegram — master bot (manages group chat, invites)
TELEGRAM_MASTER_BOT_TOKEN=your-master-bot-token
TELEGRAM_GROUP_CHAT_ID=your-group-chat-id

# AgentMail — email inboxes for agents (get pod ID from https://console.agentmail.to/)
AGENTMAIL_API_KEY=your-agentmail-api-key
AGENTMAIL_POD_ID=your-agentmail-pod-id

# Base (L2) — on-chain USDC operations
GAME_WALLET_ADDRESS=0x...
GAME_WALLET_PRIVATE_KEY=0x...

# Agent 1 — pre-funded wallet + Telegram bot
AGENT_1_ACCESS_CODE=change-me-uuid-1
AGENT_1_WALLET_ADDRESS=0x...
AGENT_1_WALLET_PRIVATE_KEY=0x...
AGENT_1_WALLET_SEED_PHRASE=word1 word2 ... word12   # required
AGENT_1_TELEGRAM_BOT_TOKEN=your-bot-token-1

# Agent 2 — pre-funded wallet + Telegram bot
AGENT_2_ACCESS_CODE=change-me-uuid-2
AGENT_2_WALLET_ADDRESS=0x...
AGENT_2_WALLET_PRIVATE_KEY=0x...
AGENT_2_WALLET_SEED_PHRASE=word1 word2 ... word12   # required
AGENT_2_TELEGRAM_BOT_TOKEN=your-bot-token-2

# Agent 3 — pre-funded wallet + Telegram bot
AGENT_3_ACCESS_CODE=change-me-uuid-3
AGENT_3_WALLET_ADDRESS=0x...
AGENT_3_WALLET_PRIVATE_KEY=0x...
AGENT_3_WALLET_SEED_PHRASE=word1 word2 ... word12   # required
AGENT_3_TELEGRAM_BOT_TOKEN=your-bot-token-3
