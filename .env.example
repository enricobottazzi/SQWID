# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/squid_games

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Discord — master bot (creates channels, invites)
DISCORD_MASTER_BOT_TOKEN=your-master-bot-token

# Agent 1 — pre-funded wallet + Discord bot
AGENT_1_ACCESS_CODE=change-me-uuid-1
AGENT_1_WALLET_ADDRESS=0x...
AGENT_1_WALLET_PRIVATE_KEY=0x...
AGENT_1_DISCORD_BOT_TOKEN=your-bot-token-1

# Agent 2 — pre-funded wallet + Discord bot
AGENT_2_ACCESS_CODE=change-me-uuid-2
AGENT_2_WALLET_ADDRESS=0x...
AGENT_2_WALLET_PRIVATE_KEY=0x...
AGENT_2_DISCORD_BOT_TOKEN=your-bot-token-2

# Agent 3 — pre-funded wallet + Discord bot
AGENT_3_ACCESS_CODE=change-me-uuid-3
AGENT_3_WALLET_ADDRESS=0x...
AGENT_3_WALLET_PRIVATE_KEY=0x...
AGENT_3_DISCORD_BOT_TOKEN=your-bot-token-3
